---
import { Icon } from 'astro-icon/components';
import { marked } from 'marked';
import type { Hero as HeroProps } from '../types';
import Button from './Button.astro';
import CustomImage from './CustomImage.astro';

type Props = HeroProps;

const { title, titleImage, subtitle, image, text, actions } = Astro.props;
---

{
    (title || titleImage?.src || image?.src || text || (actions && actions.length > 0)) && (
        <section class="mb-16 flex w-full flex-col gap-8 sm:mb-24">
            {titleImage?.src ? (
                <h1 class="h-12 sm:h-[4.5rem] [&>img]:h-full [&>img]:w-auto [&>img]:object-contain [&>img]:dark:invert">
                    <CustomImage
                        src={titleImage.src}
                        alt={titleImage.alt ?? ''}
                        class="h-full w-auto object-contain dark:invert"
                        loading="eager"
                        fetchpriority="high"
                    />
                </h1>
            ) : title ? (
                <h1 class="font-sans text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight">
                    {title}
                </h1>
            ) : null}
            {subtitle && (
                <p class="flex items-center gap-3 text-theme-foreground">
                    {subtitle}
                </p>
            )}
            {image?.src && (
                <figure>
                    <CustomImage
                        class="w-full"
                        {...image}
                        widths={[480, 640, 768, 1024, 1536]}
                        sizes="(min-width: 832px) 768px, calc(100vw - 32px)"
                        fetchpriority="high"
                        loading="eager"
                    />
                    {image.caption && <figcaption class="mt-1.5 text-xs sm:text-sm">{image.caption}</figcaption>}
                </figure>
            )}
            {text && <div class="prose max-w-none prose-hero" set:html={marked.parse(text)} />}
            {actions && actions.length > 0 && (
                <div class="flex flex-wrap gap-4">
                    {actions.map((action) => (
                        <Button href={action.href}>{action.text}</Button>
                    ))}
                </div>
            )}
        </section>
    )
}
